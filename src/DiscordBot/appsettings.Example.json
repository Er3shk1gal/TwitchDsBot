{
  "Discord": {
    "Token": "your-discord-bot-token",
    "DebugGuildId": null
  },
  "Music": {
    "FfmpegPath": "ffmpeg",
    "YtDlpPath": "yt-dlp",
    "DefaultSearchPrefix": "scsearch",
    "DefaultVolume": 1.0,
    "IdleTimeoutSeconds": 120
  },
  "YouTube": {
    "ApiKey": "your-youtube-data-api-v3-key",
    "PollIntervalSeconds": 180
  },
  "Database": {
    "ConnectionString": "Data Source=bot.db"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  }
}
