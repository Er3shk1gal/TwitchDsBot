<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net9.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <RootNamespace>DiscordBot</RootNamespace>
    <AssemblyName>DiscordBot</AssemblyName>
    <!-- DSharpPlus 5 nightly is a prerelease; silence NU5104 prerelease-dependency noise. -->
    <NoWarn>$(NoWarn);NU5104</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <!-- Discord -->
    <PackageReference Include="DSharpPlus" Version="5.0.0-nightly-02594" />
    <PackageReference Include="DSharpPlus.Commands" Version="5.0.0-nightly-02594" />

    <!-- Music: pure-.NET voice. Audio is fetched with yt-dlp, transcoded with FFmpeg,
         and streamed to Discord through VoiceNext. yt-dlp + ffmpeg must be on PATH. -->
    <PackageReference Include="DSharpPlus.VoiceNext" Version="5.0.0-nightly-02594" />

    <!-- YouTube notifier -->
    <PackageReference Include="Google.Apis.YouTube.v3" Version="1.75.0.4207" />

    <!-- Persistence -->
    <PackageReference Include="Microsoft.EntityFrameworkCore.Sqlite" Version="9.0.4" />
    <PackageReference Include="Microsoft.EntityFrameworkCore.Design" Version="9.0.4">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>

    <!-- Host / config / logging (9.0.4 floor required by DSharpPlus 5 nightly) -->
    <PackageReference Include="Microsoft.Extensions.Hosting" Version="9.0.4" />
    <PackageReference Include="Microsoft.Extensions.Http" Version="9.0.4" />
  </ItemGroup>

  <ItemGroup>
    <None Update="appsettings.json" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

</Project>
