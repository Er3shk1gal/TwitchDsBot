# Copy to `.env` (or set as real environment variables) and fill in.
# Environment variables override appsettings.json. Double underscore = nested key.

# --- Discord ---
DISCORD__TOKEN=your-discord-bot-token
# Optional: register slash commands instantly to this guild during development.
# Leave empty to register commands globally (can take up to 1h to propagate).
DISCORD__DEBUGGUILDID=

# --- Music / radio (playback via Lavalink) ---
# The bot talks to the Lavalink container. docker-compose already sets the address + password for
# you; only change these if you run Lavalink elsewhere. LAVALINK_PASSWORD sets the server's password
# AND the bot's (compose keeps them in sync); default is fine since Lavalink binds to loopback only.
LAVALINK_PASSWORD=youshallnotpass
# Search prefix for non-URL /play queries: scsearch (SoundCloud), bcsearch (Bandcamp), ytsearch
# (YouTube — needs the youtube-source plugin on the Lavalink server).
MUSIC__DEFAULTSEARCHMODE=scsearch

# --- YouTube notifier ---
YOUTUBE__APIKEY=your-youtube-data-api-v3-key
YOUTUBE__POLLINTERVALSECONDS=180

# --- Twitch notifier (used by /notify twitch — "channel went live") ---
# App credentials from https://dev.twitch.tv/console/apps (client-credentials grant; no user login).
# Leave both empty to disable /notify twitch entirely.
TWITCH__CLIENTID=
TWITCH__CLIENTSECRET=

# --- Telegram notifier sink (used by /notify telegram to mirror an existing subscription) ---
# Bot token from @BotFather. Leave empty to disable; without it /notify telegram reports unavailable.
TELEGRAM__BOTTOKEN=

# --- Twitch chat responder ("!links" copypasta) ---
# A USER OAuth token (chat:read + chat:edit scopes) for the account that should post in chat — this
# is different from TWITCH__CLIENTID/SECRET above, which can only read Helix, not send chat messages.
# Get one at https://twitchtokengenerator.com (or your own OAuth app) and paste with or without the
# "oauth:" prefix. Leave empty to disable. Channels is a list — env vars need index suffixes:
TWITCHCHAT__OAUTHTOKEN=
TWITCHCHAT__BOTUSERNAME=
TWITCHCHAT__CHANNELS__0=your-channel-login
TWITCHCHAT__COMMAND=!links
TWITCHCHAT__MESSAGE=My socials: https://twitter.com/you | https://instagram.com/you | https://discord.gg/your-invite
TWITCHCHAT__COOLDOWNSECONDS=15

# --- Database ---
DATABASE__CONNECTIONSTRING=Data Source=bot.db
