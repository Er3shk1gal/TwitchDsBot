# Copy to `.env` (or set as real environment variables) and fill in.
# Environment variables override appsettings.json. Double underscore = nested key.

# --- Discord ---
DISCORD__TOKEN=your-discord-bot-token
# Optional: register slash commands instantly to this guild during development.
# Leave empty to register commands globally (can take up to 1h to propagate).
DISCORD__DEBUGGUILDID=

# --- Music / radio (playback via Lavalink) ---
# The bot talks to the Lavalink container. docker-compose already sets the address + password for
# you; only change these if you run Lavalink elsewhere. LAVALINK_PASSWORD sets the server's password
# AND the bot's (compose keeps them in sync); default is fine since Lavalink binds to loopback only.
LAVALINK_PASSWORD=youshallnotpass
# Search prefix for non-URL /play queries: scsearch (SoundCloud), bcsearch (Bandcamp), ytsearch
# (YouTube — needs the youtube-source plugin on the Lavalink server).
MUSIC__DEFAULTSEARCHMODE=scsearch

# --- YouTube notifier ---
YOUTUBE__APIKEY=your-youtube-data-api-v3-key
YOUTUBE__POLLINTERVALSECONDS=180

# --- Database ---
DATABASE__CONNECTIONSTRING=Data Source=bot.db
